<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PanditaAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/panditaAS.styles.css" asp-append-version="true" />

    <style>
        /* 🌌 Fondo azul oscuro profundo para toda la aplicación */
        body {
            background: radial-gradient(circle, #1c2541 0%, #0b132b 100%) fixed;
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* 🟦 Navbar personalizada estilo Cyberpunk / Anime */
        .navbar-custom {
            background-color: #0b132b !important;
            border-bottom: 2px solid #00b4d8 !important;
            box-shadow: 0 0 15px rgba(0, 180, 216, 0.4);
        }

        .navbar-brand-custom {
            color: #00f5d4 !important;
            font-weight: bold;
            text-shadow: 0 0 10px rgba(0, 245, 212, 0.6);
        }

        .nav-link-custom {
            color: #00b4d8 !important;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .nav-link-custom:hover {
                color: #00f5d4 !important;
                text-shadow: 0 0 8px rgba(0, 245, 212, 0.8);
            }

        /* 📞 Botón especial de WhatsApp de Contacto */
        .nav-contact-btn {
            color: #00f5d4 !important;
            border: 1px solid #00f5d4;
            border-radius: 20px;
            padding: 5px 15px !important;
            margin-left: 10px;
            box-shadow: 0 0 8px rgba(0, 245, 212, 0.2);
        }

            .nav-contact-btn:hover {
                background-color: #00f5d4;
                color: #0b132b !important;
                box-shadow: 0 0 15px rgba(0, 245, 212, 0.6);
            }

        /* 🧦 Footer Oscuro Estilizado */
        .footer-custom {
            background-color: #070d1f;
            border-top: 1px solid #1c2541;
            color: #64748b !important;
        }

            .footer-custom a {
                color: #00b4d8;
                text-decoration: none;
            }

                .footer-custom a:hover {
                    color: #00f5d4;
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-custom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand navbar-brand-custom" asp-area="" asp-controller="Home" asp-action="Index">🐼 PanditaAS</a>
                <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link nav-contact-btn" href="https://wa.me/50233245898?text=Hola,%20vi%20tu%20Biblioteca%20Manga%20Interactiva" target="_blank">
                                💬 Contact
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom footer text-muted text-center py-3">
        <div class="container">
            &copy; 2026 - PanditaAS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>